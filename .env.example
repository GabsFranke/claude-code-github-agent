# Anthropic API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Alternative: Use ANTHROPIC_AUTH_TOKEN instead of ANTHROPIC_API_KEY
# ANTHROPIC_AUTH_TOKEN=your_auth_token_here

# Optional: Use alternative providers (choose ONE option below)

# Option 1: Z.AI (GLM models via Anthropic-compatible API)
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# ANTHROPIC_DEFAULT_HAIKU_MODEL=GLM-4.5-Air
# ANTHROPIC_DEFAULT_SONNET_MODEL=GLM-4.7
# ANTHROPIC_DEFAULT_OPUS_MODEL=GLM-4.7

# Option 2: Vertex AI (Claude models via Google Cloud)
# Requires: gcloud auth application-default login
# ANTHROPIC_API_KEY=sk-ant-unused
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# ANTHROPIC_VERTEX_REGION=global

# GitHub App Authentication (required)
# Get these from your GitHub App settings
GITHUB_APP_ID=your_app_id
GITHUB_INSTALLATION_ID=your_installation_id
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
your_private_key_here
-----END RSA PRIVATE KEY-----"

# Bot Identity Configuration
# BOT_USERNAME: Display name for git commits (can have spaces)
# BOT_USER_EMAIL: Email for git commits
BOT_USERNAME=Claude Code Agent
BOT_USER_EMAIL=claude-code-agent[bot]@users.noreply.github.com

# Webhook Configuration
# WEBHOOK_BOT_USERNAME: GitHub login username (no spaces, must match GitHub App username)
# Used to prevent infinite loops when bot creates PRs
# Example: "mybot[bot]" or "simplegithubagent[bot]"
WEBHOOK_BOT_USERNAME=claude-code-agent[bot]

# Message Queue Configuration (Redis for self-hosted)
QUEUE_TYPE=redis
REDIS_URL=redis://localhost:6379
QUEUE_NAME=agent-requests

# Security: Database and Service Credentials
# IMPORTANT: Change these defaults in production!
REDIS_PASSWORD=changeme

# Langfuse Database Configuration
LANGFUSE_DB_NAME=langfuse
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=changeme

# Other Service Credentials
CLICKHOUSE_PASSWORD=changeme
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=changeme

# Langfuse Security Keys
LANGFUSE_SALT=changeme-generate-a-salt-here
LANGFUSE_NEXTAUTH_SECRET=changeme-generate-a-secret-here
LANGFUSE_ENCRYPTION_KEY=66dcdfca97e12b2225f09fefdafc54b7563bdaca9efc95d490b3aae290b40d8f

# Service Configuration
PORT=8080
LOG_LEVEL=INFO

# SDK Debug Mode (optional)
# Set to "true" to enable verbose SDK logging (model, prompt, tools, messages)
# Default: false (only shows essential logs)
SDK_DEBUG=false

# Host MCP Integration (optional)
# Allow agent to use host's Claude Code MCP servers (e.g. from ~/.claude.json)
# Default: true
ALLOW_HOST_MCP=true

# Post-session workers (optional)
# MEMORY_WORKER_ENABLED: extract and persist facts from session transcripts (memory_worker)
# RETROSPECTOR_ENABLED: analyse sessions for agent instruction improvements (retrospector_worker)
# BOT_REPO: the bot's own repository — retrospector opens improvement PRs here
MEMORY_WORKER_ENABLED=true
RETROSPECTOR_ENABLED=true
BOT_REPO=GabsFranke/claude-code-github-agent

# Timeout Configuration (optional)
# SDK execution timeout in seconds (default: 1800 = 30 minutes)
SDK_EXECUTION_TIMEOUT=1800
# SDK retry configuration (default: 3 retries with 5s base delay)
# Exponential backoff: 5s, 15s, 30s delays
SDK_MAX_RETRIES=3
SDK_RETRY_BASE_DELAY=5.0
# Repository sync lock timeout in seconds (default: 300 = 5 minutes)
REPO_SYNC_LOCK_TIMEOUT=300
# Langfuse hook timeout in seconds (default: 30)
LANGFUSE_HOOK_TIMEOUT=30

# Session Streaming Configuration (optional)
# Public URL where the session_proxy service is accessible
# Used to generate live-view links in GitHub comments
# Example: http://localhost:10001 (local dev) or https://bot.yourdomain.com (production)
# SESSION_PROXY_URL=http://localhost:10001

# Health Check Configuration (optional)
HEALTH_CHECK_INTERVAL=30  # Update interval in seconds
HEALTH_CHECK_FILE=/tmp/worker_health  # Health file path
HEALTH_CHECK_MAX_IDLE=1800  # Max idle time before unhealthy (30 minutes)

# Rate Limiting Configuration (optional)
GITHUB_RATE_LIMIT=5000  # Requests per hour
ANTHROPIC_RATE_LIMIT=100  # Requests per minute

# Langfuse Observability (optional - for debugging agent traces)
# Pre-configured for self-hosted setup:
# - Access at: http://localhost:7500
# - Default login: admin@example.com / changeme (change LANGFUSE_INIT_USER_PASSWORD)
LANGFUSE_PUBLIC_KEY=lf_pk_github_agent_public
LANGFUSE_SECRET_KEY=lf_sk_github_agent_secret
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_PASSWORD=changeme
# LANGFUSE_HOST is set automatically in docker-compose to http://localhost:7500

# Langfuse Trace Linking
# Links agent sessions to subagent invocations in Langfuse for hierarchical trace visualization
# When enabled, main agent sessions become parent traces with subagent calls as children
# This provides better observability for debugging complex multi-agent interactions
# Default: true (recommended for production observability)
LANGFUSE_TRACE_LINKING=true

# Semantic Code Search (optional)
# Enable embedding-based code search via Google Gemini + SurrealDB
# Get your API key from https://aistudio.google.com/apikey
# INDEXING_ENABLED=true
# GEMINI_API_KEY=your_gemini_api_key_here
# SURREALDB_URL=ws://localhost:8000/rpc
# SURREALDB_USER=root
# SURREALDB_PASS=root
# SURREALDB_NS=bot
# SURREALDB_DB=codebase
# Optional overrides (defaults shown):
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIMENSION=1024
# EMBEDDING_BATCH_SIZE=20

# Session proxy URL (used by worker to communicate with session proxy)
SESSION_PROXY_URL=http://localhost:10001

# Disable non-essential Claude Code SDK traffic (telemetry, updates)
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Allowed origins for session proxy WebSocket CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Allow host MCP servers to be discovered by agents
ALLOW_HOST_MCP=1
